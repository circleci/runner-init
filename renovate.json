{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["local>circleci/renovate-config"],
  "baseBranchPatterns": ["main"],
  "osvVulnerabilityAlerts": true,
  "dependencyDashboardOSVVulnerabilitySummary": "all",
  "packageRules": [
    {
      "groupName": "go dependencies (patch versions)",
      "description": "Group all patch updates into a single pull request",
      "matchUpdateTypes": "patch",
      "matchDatasources": [
        "go"
      ]
    },
    {
      "groupName": "go version",
      "description": "Upgrade Go version in various places to keep them consistent",
      "matchDepNames": [
        "golang",
        "cimg/go",
        "go"
      ]
    },
    {
      "description": "Automerge CVE/Security updates",
      "matchJsonata": ["$exists(isVulnerabilityAlert) and isVulnerabilityAlert = true"],
      "automerge": true,
      "automergeSchedule": [
        "* 8-17 * * 1-5"
      ],
      "labels": [
        "AUTOMERGE", "CVE", "security"
      ]
    }
  ]
}
